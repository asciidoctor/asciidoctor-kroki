{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["es2022", "dom"],
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "outDir": "build/types",
    "resolveJsonModule": true,
    "types": ["node"],
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src"]
}